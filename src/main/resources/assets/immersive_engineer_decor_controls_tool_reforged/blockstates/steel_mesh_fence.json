{
  "multipart": [
    { "when": { "up":    "true" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_post" } },
    { "when": { "north": "low" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "uvlock": true } },
    { "when": { "east":  "low" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 90, "uvlock": true } },
    { "when": { "south": "low" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 180, "uvlock": true } },
    { "when": { "west":  "low" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 270, "uvlock": true } },
    { "when": { "north": "tall" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "uvlock": true } },
    { "when": { "east":  "tall" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 90, "uvlock": true } },
    { "when": { "south": "tall" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 180, "uvlock": true } },
    { "when": { "west":  "tall" }, "apply": { "model": "immersive_engineer_decor_controls_tool_reforged:block/fence/steel_mesh_fence_side", "y": 270, "uvlock": true } }
  ]
}
